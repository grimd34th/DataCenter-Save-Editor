<Window x:Class="DataCenterSaveEditor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Center Save Editor" Height="820" Width="1320"
        MinHeight="640" MinWidth="980" WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F6F8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#17212B" Padding="14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="DATA CENTER" Foreground="#8ED0FF" FontSize="13" FontWeight="Bold" />
                    <TextBlock Text="Save Editor" Foreground="White" FontSize="25" Margin="0,2,0,16" />
                    <TextBlock Text="Paired saves" Foreground="#B9C5CF" FontWeight="SemiBold" Margin="0,0,0,6" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" />
                    <Button Content="Open .save…" Command="{Binding OpenCommand}" />
                    <Button Content="Load selected" Command="{Binding LoadCommand}" />
                    <TextBlock Text="Backups are created beside the saves before either file is replaced."
                               Foreground="#91A0AC" TextWrapping="Wrap" FontSize="11" Margin="4,12,4,0" />
                </StackPanel>

                <ListBox ItemsSource="{Binding SavePairs}" SelectedItem="{Binding SelectedPair}"
                         Background="#202D39" Foreground="White" BorderBrush="#344554" Padding="3">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5">
                                <TextBlock Text="{Binding BaseName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding SavePath}" Foreground="#9FB0BE" FontSize="10" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Margin="2,0,0,12">
                <TextBlock Text="{Binding DocumentTitle}" FontSize="23" FontWeight="SemiBold" Foreground="#17212B" />
                <TextBlock Text="{Binding Status}" Foreground="#52616D" TextWrapping="Wrap" Margin="0,4,0,0" />
            </StackPanel>

            <TabControl Grid.Row="1">
                <TabItem Header="Common fields">
                    <DataGrid ItemsSource="{Binding CommonFields}" AutoGenerateColumns="False" CanUserAddRows="False"
                              CanUserDeleteRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowHeaderWidth="0" Margin="8" IsReadOnly="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Field" Binding="{Binding DisplayName}" IsReadOnly="True" Width="210" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" IsReadOnly="True" Width="100" />
                            <DataGridTemplateColumn Header="Value" Width="260">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                 IsReadOnly="{Binding IsReadOnly}" BorderThickness="0" Background="Transparent" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Validation" Binding="{Binding ValidationMessage}" IsReadOnly="True" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Advanced object tree">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Search" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="SemiBold" />
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </DockPanel>
                        <TreeView Grid.Row="1" ItemsSource="{Binding AdvancedRoots}" SelectedItemChanged="AdvancedTree_SelectedItemChanged"
                                  VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock Text="{Binding Display}" ToolTip="{Binding Path}" />
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                        <Border Grid.Row="2" BorderBrush="#CAD2D9" BorderThickness="1" Padding="10" Margin="0,8,0,0" Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="Path" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedPath}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="1" Text="Type" FontWeight="SemiBold" Margin="0,5,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedType}" Margin="0,5,0,0" />
                                <TextBlock Grid.Row="2" Text="Value" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,7,0,0" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding AdvancedValue, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding CanEditAdvanced}" Margin="0,7,8,0" />
                                <Button Grid.Row="2" Grid.Column="2" Content="Apply" Command="{Binding ApplyAdvancedCommand}" Margin="0,5,0,0" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Text="{Binding AdvancedValidation}"
                                           Foreground="#B3261E" TextWrapping="Wrap" Margin="0,4,0,0" />
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>

            <DockPanel Grid.Row="2" Margin="0,12,0,0">
                <TextBlock Text="Only existing scalar leaves can be changed. Collections and object structure remain fixed."
                           VerticalAlignment="Center" Foreground="#667680" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Revert" Command="{Binding RevertCommand}" />
                    <Button Content="Save changes" Command="{Binding SaveCommand}" Background="#1570A6" Foreground="White" />
                </StackPanel>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
